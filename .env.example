SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Direct Message API (programmatic access to NanoClaw)
# Set a token to enable the API channel. Leave empty to disable.
NANOCLAW_API_TOKEN=
# HTTP port (default: 3200)
NANOCLAW_API_PORT=3200
# Response timeout in ms (default: 120000 = 2 minutes)
NANOCLAW_API_TIMEOUT=120000
