{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "fleet-host": {
      "type": "stdio",
      "command": "node",
      "args": [
        "/workspace/global/mcp-socket-bridge.js",
        "/tmp/fleet-host-mcp.sock"
      ]
    }
  }
}
